{
  "skill": "erddap-sst-analysis",
  "version": "0.1.0",
  "inputs": {
    "variable": {
      "type": "string",
      "enum": ["sst"],
      "description": "Fixed value for this skill"
    },
    "bbox": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["pacific_mexico", "gulf_mexico"],
          "description": "Predefined region shorthand"
        },
        {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4,
          "description": "[lon_min, lon_max, lat_min, lat_max]"
        }
      ]
    },
    "date_range": {
      "type": "array",
      "items": { "type": "string", "format": "date" },
      "minItems": 2,
      "maxItems": 2,
      "description": "['YYYY-MM-DD', 'YYYY-MM-DD']. Max span: 5 years."
    },
    "sst_var": {
      "type": "string",
      "enum": ["sst", "anom", "err", "ice"],
      "default": "sst",
      "description": "sst=temperatura °C | anom=anomalía vs climatología °C | err=error estimado °C | ice=concentración hielo 0-1"
    },
    "source": {
      "type": "string",
      "enum": ["auto", "mur_1km", "mur_anomaly"],
      "default": "auto",
      "description": "'auto' uses OISST 0.25° default. mur_1km for high spatial resolution."
    }
  },
  "required": ["variable", "bbox", "date_range"],
  "outputs": {
    "type": "object",
    "properties": {
      "data": {
        "values": "array[time][lat][lon] — values in units of sst_var",
        "times": "array of 'YYYY-MM-DD' strings",
        "lat": "array of latitude values",
        "lon": "array of longitude values"
      },
      "meta": {
        "variable": "sst",
        "source": "'local' | 'cache' | 'erddap'",
        "shape": "[n_times, n_lat, n_lon]"
      }
    }
  },
  "notes": [
    "Default dataset: ncdcOisst21Agg_LonPM180 (OISST v2.1, 0.25°, daily, 1981-present)",
    "Typical SST range Mexican seas: 14-32°C",
    "Anomaly baseline: 1971-2000 climatology",
    "ice is always 0 in Mexican seas — only useful for high-latitude queries"
  ]
}
